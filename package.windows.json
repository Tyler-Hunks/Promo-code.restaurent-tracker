{
  "name": "promo-code-manager-windows",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "npm run build:frontend && npm run build:worker",
    "build:frontend": "vite build --config vite.config.cloudflare.ts",
    "build:worker": "esbuild server/worker.ts --platform=browser --format=esm --bundle --outdir=dist --outfile=worker.js --external:node:* --define:process.env.NODE_ENV=\"production\" --minify",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "deploy": "npm run build && wrangler deploy",
    "deploy:prod": "npm run build && wrangler deploy --env production",
    "deploy:preview": "npm run build && wrangler deploy --env preview",
    "postinstall": "npm run check"
  }
}